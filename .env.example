
# HeyGen — video generation REST API (X-Api-Key)
HEYGEN_API_KEY=...

# Anthropic — OPTIONAL. Only needed to *write* a script for a row that has no
# `script` cell. If every row in your CSV has a script, leave this unset.
# ANTHROPIC_API_KEY=...

# Optional overrides (defaults live in src/config.ts)
# HEYGEN_BASE_URL=https://api.heygen.com
# MAX_CONCURRENCY=3
